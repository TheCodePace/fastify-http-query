{
  "name": "@thecodepace/fastify-http-query",
  "version": "0.0.2",
  "description": "Plugin to enable HTTP query method in Fastify.",
  "main": "index.js",
  "type": "module",
  "types": "types/index.d.ts",
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "npm run unit && npm run typescript",
    "typescript": "tstyche",
    "unit": "c8 --100 node --test",
    "release": "release-it",
    "release:dry": "release-it --ci --dry-run --no-npm.publish",
    "release:ci": "release-it --ci",
    "prepare": "lefthook install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheCodePace/fastify-http-query.git"
  },
  "keywords": [
    "fastify",
    "http",
    "query",
    "plugin"
  ],
  "author": "Luca Del Puppo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TheCodePace/fastify-http-query/issues"
  },
  "homepage": "https://github.com/TheCodePace/fastify-http-query#readme",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@fastify/caching": "^9.0.3",
    "@fastify/etag": "^6.1.0",
    "@types/node": "^25.0.3",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "fastify": "^5.0.0",
    "lefthook": "^2.1.9",
    "neostandard": "^0.13.0",
    "proxyquire": "^2.1.3",
    "release-it": "^20.2.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "tstyche": "^7.2.1"
  },
  "dependencies": {
    "@fastify/error": "^4.0.0",
    "fastify-plugin": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): v${version}",
      "tagName": "v${version}",
      "requireBranch": false,
      "requireCleanWorkingDir": true
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "npm": {
      "publish": "public",
      "provenance": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "conventionalcommits"
        },
        "infile": "CHANGELOG.md"
      }
    }
  }
}
